# Продакшен: HTTP → HTTPS, Laravel, Let's Encrypt.
# 1) Поправьте upstream (socket PHP-FPM) и root при необходимости.
# 2) Выпустите сертификат (deploy/certbot-issue.sh) или положите pem по указанным путям.
# 3) sudo cp … /etc/nginx/sites-available/admin.sarasvatiplace.online.conf
#    sudo ln -sf … /etc/nginx/sites-enabled/ && sudo nginx -t && sudo systemctl reload nginx

upstream php_fpm_nhc_admin {
    server unix:/run/php/php8.4-fpm.sock;
}

server {
    listen 80;
    listen [::]:80;
    server_name admin.sarasvatiplace.online;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/nhc-admin/public;
        default_type "text/plain";
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name admin.sarasvatiplace.online;

    root /var/www/nhc-admin/public;
    index index.php;
    charset utf-8;

    ssl_certificate     /etc/letsencrypt/live/admin.sarasvatiplace.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/admin.sarasvatiplace.online/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    # При наличии файла: ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_pass php_fpm_nhc_admin;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param HTTPS on;
        fastcgi_param HTTP_X_FORWARDED_PROTO $scheme;
        fastcgi_hide_header X-Powered-By;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
