# Рабочий пример: HTTP по IP (совпадает с тем, что можно положить в sites-available).
# Установка на сервере (root):
#   ./deploy/install-nginx-ip.sh
# Или вручную:
#   cp deploy/nginx-ip-http.conf.example /etc/nginx/sites-available/nhc-admin.conf
#   ln -sf /etc/nginx/sites-available/nhc-admin.conf /etc/nginx/sites-enabled/
#   rm -f /etc/nginx/sites-enabled/default
#   nginx -t && systemctl reload nginx

upstream php_fpm_nhc_admin {
    server unix:/run/php/php8.4-fpm.sock;
}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name 83.222.27.146 _;

    root /var/www/nhc-admin/public;
    index index.php;
    charset utf-8;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_pass php_fpm_nhc_admin;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param HTTP_X_FORWARDED_PROTO $scheme;
        fastcgi_hide_header X-Powered-By;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
