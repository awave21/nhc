APP_NAME=NHC
APP_ENV=production
APP_KEY=base64:mEV8BXFqokCpakmukpV5/oTTFihdpkdFUIkZvWuJvmc=
APP_DEBUG=false
# Временно по IP; с DNS и сертификатом: https://admin.sarasvatiplace.online
APP_URL=http://83.222.27.146

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# database — данные через Laravel к PostgreSQL (DB_*); URL и ключи Supabase не нужны.
# postgrest — запросы к PostgREST; тогда нужны SUPABASE_URL и ключ ниже.
SUPABASE_DRIVER=database
SUPABASE_DB_CONNECTION=pgsql
# --- Ниже только для SUPABASE_DRIVER=postgrest (при database можно не задавать) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DIALOGS_TABLE=dialogs
# Фильтр по колонке user_id = id пользователя Laravel (если колонка есть в таблице)
SUPABASE_DIALOGS_SCOPE_TO_USER=false
SUPABASE_DIALOGS_USER_ID_COLUMN=user_id
# Уникальность диалога в списке бесед
SUPABASE_DIALOGS_THREAD_ID_COLUMN=tg_chat_id
SUPABASE_DIALOGS_CONVERSATION_TITLE_COLUMN=tg_username
SUPABASE_DIALOGS_FETCH_ORDER=desc
SUPABASE_DIALOGS_FETCH_BATCH_SIZE=1000
SUPABASE_DIALOGS_FETCH_MAX_BATCHES=500
SUPABASE_DIALOGS_FETCH_TIMEOUT=60
SUPABASE_AGENT_DISPLAY_NAME=Виктория
# SUPABASE_AGENT_AVATAR_URL=
# Переименование колонок таблицы при необходимости:
# SUPABASE_DIALOGS_COL_BODY=content
# SUPABASE_DIALOGS_COL_SENDER=sender

# Только для postgrest: отдельный anon для read-only; иначе ANON_KEY / service_role
SUPABASE_CLIENT_ANON_KEY=
SUPABASE_EVENT_REGISTRATIONS_TABLE=event_registrations
# Колонка со значением для ссылки «Диалог» (username из заявки)
SUPABASE_EVENT_REGISTRATIONS_DIALOG_COLUMN=tg_username
# username → /dialogi?username=… (совпадение с @title беседы); chat_id → ?conversation= (tg_chat_id)
SUPABASE_EVENT_REGISTRATIONS_DIALOG_LINK_MATCH=username
SUPABASE_EVENT_REGISTRATIONS_FETCH_BATCH_SIZE=1000
SUPABASE_EVENT_REGISTRATIONS_FETCH_MAX_BATCHES=50
SUPABASE_EVENT_REGISTRATIONS_FETCH_TIMEOUT=60

# Страница «Профили пользователей» (/user-profiles): таблица заметок user_profile
SUPABASE_USER_PROFILE_TABLE=user_profile
SUPABASE_USER_PROFILE_USERNAME_COLUMN=username
SUPABASE_USER_PROFILE_DESCRIPTION_COLUMN=description
SUPABASE_USER_PROFILE_CREATED_AT_COLUMN=created_at
SUPABASE_USER_PROFILE_FETCH_BATCH_SIZE=1000
SUPABASE_USER_PROFILE_FETCH_MAX_BATCHES=50
SUPABASE_USER_PROFILE_FETCH_TIMEOUT=60

# Страница «Документация» → «Общие сведения»: блок учётных данных после кодового слова (не коммить реальные значения)
DOCUMENTATION_PASSPHRASE=Sarasvatii
DOCUMENTATION_SUPABASE_URL=https://supabase.nhc.live
# Многострочный текст: логин/пароль или ref + anon key (см. Supabase → Settings → API)
DOCUMENTATION_SUPABASE_CREDENTIALS=
DOCUMENTATION_LIGHTRAG_URL=https://lightrag.nhc.live/webui/#/
# Веб-панель Coolify (страница входа или дашборд; ссылка в «Общих сведениях»)
DOCUMENTATION_COOLIFY_PANEL_URL=https://coolify.nhc.live/login
DOCUMENTATION_COOLIFY_EMAIL=
DOCUMENTATION_COOLIFY_PASSWORD=
DOCUMENTATION_REDIS_NOTE=

OPENAI_API_KEY=
API_TOKEN=
