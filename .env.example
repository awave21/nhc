APP_NAME=NHC
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=nhc
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Supabase (PostgREST) — диалоги на странице /dialogi
# Не публикуйте service_role во фронтенд; только в .env на сервере.
SUPABASE_URL=https://supabase.nhc.live
# Опционально: отдельный anon для публичных read (страница Order); иначе используется SUPABASE_ANON_KEY
SUPABASE_CLIENT_ANON_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DIALOGS_TABLE=dialogs
# Фильтр по колонке user_id = id пользователя Laravel (если колонка есть в таблице)
SUPABASE_DIALOGS_SCOPE_TO_USER=false
SUPABASE_DIALOGS_USER_ID_COLUMN=user_id
# Уникальность диалога: tg_chat_id (можно переопределить; пустое значение — все в «_default»)
SUPABASE_DIALOGS_THREAD_ID_COLUMN=tg_chat_id
SUPABASE_DIALOGS_CONVERSATION_TITLE_COLUMN=tg_username
# Порядок выборки: desc — сначала свежие сообщения (рекомендуется), asc — с «начала» таблицы.
SUPABASE_DIALOGS_FETCH_ORDER=desc
# PostgREST: limit/offset за запрос; при лимите батчей кнопка «Загрузить ещё» на /dialogi
SUPABASE_DIALOGS_FETCH_BATCH_SIZE=1000
SUPABASE_DIALOGS_FETCH_MAX_BATCHES=500
SUPABASE_DIALOGS_FETCH_TIMEOUT=60
SUPABASE_AGENT_DISPLAY_NAME=Виктория
# SUPABASE_AGENT_AVATAR_URL=
# Переименование колонок таблицы при необходимости:
# SUPABASE_DIALOGS_COL_BODY=content
# SUPABASE_DIALOGS_COL_SENDER=sender
#
# Supabase — страница /order (Order), таблица event_registrations
# SUPABASE_EVENT_REGISTRATIONS_TABLE=event_registrations
# Колонка для ссылки «Диалог» (значение из строки заявки)
# SUPABASE_EVENT_REGISTRATIONS_DIALOG_COLUMN=tg_chat_id
# Режим: chat_id → ?conversation= ; username → ?username= (как @title в списке диалогов)
# SUPABASE_EVENT_REGISTRATIONS_DIALOG_LINK_MATCH=chat_id
# Пример по username: DIALOG_COLUMN=tg_username и DIALOG_LINK_MATCH=username
# SUPABASE_EVENT_REGISTRATIONS_FETCH_BATCH_SIZE=1000
# SUPABASE_EVENT_REGISTRATIONS_FETCH_MAX_BATCHES=50
# SUPABASE_EVENT_REGISTRATIONS_FETCH_TIMEOUT=60
#
# Supabase — страница /appeals (Обращения), таблица escalation_message
# SUPABASE_ESCALATION_MESSAGE_TABLE=escalation_message
# SUPABASE_ESCALATION_MESSAGE_DIALOG_COLUMN=tg_chat_id
# SUPABASE_ESCALATION_MESSAGE_DIALOG_LINK_MATCH=chat_id
# SUPABASE_ESCALATION_MESSAGE_FETCH_BATCH_SIZE=1000
# SUPABASE_ESCALATION_MESSAGE_FETCH_MAX_BATCHES=50
# SUPABASE_ESCALATION_MESSAGE_FETCH_TIMEOUT=60
